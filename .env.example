# Configuración de usuarios para el login
# Copia este archivo a .env y rellena los valores

# Usuario 1
VITE_USER_1_ID=moi
VITE_USER_1_NAME=Moi
VITE_USER_1_AVATAR=👨
VITE_USER_1_PASSWORD_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Usuario 2
VITE_USER_2_ID=manu
VITE_USER_2_NAME=Manu
VITE_USER_2_AVATAR=👨
VITE_USER_2_PASSWORD_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Nota: Los hashes de contraseña deben generarse con SHA-256.
# Puedes generar el hash de una contraseña usando:
# - En Node.js: node -e "console.log(require('crypto').createHash('sha256').update('tu_password').digest('hex'))"
# - O usa la consola del navegador: generatePasswordHash('tu_password') (exportada desde authService)